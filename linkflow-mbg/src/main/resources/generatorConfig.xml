<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="DemoContext" targetRuntime="MyBatis3Simple">
        <commentGenerator>
            <property name="suppressAllComments" value="true"/>
        </commentGenerator>
        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/short_link_db"
                        userId="root"
                        password="123456"/>
        <javaModelGenerator targetPackage="com.linkFlow.workflow.model" targetProject="linkflow-workflow/src/main/java"/>
        <sqlMapGenerator targetPackage="mapper" targetProject="linkflow-workflow/src/main/resources"/>
        <javaClientGenerator type="XMLMAPPER" targetPackage="com.linkFlow.workflow.mapper" targetProject="linkflow-workflow/src/main/java"/>
        <table tableName="approval_record" domainObjectName="ApprovalRecord" catalog="short_link_db"/>
    </context>
</generatorConfiguration>
