<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE generatorConfiguration
        PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">

<generatorConfiguration>
    <context id="DemoContext" targetRuntime="MyBatis3Simple">
        <commentGenerator>
            <property name="suppressAllComments" value="true"/>
        </commentGenerator>
        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/short_link_db"
                        userId="root"
                        password="123456"/>
        <javaModelGenerator targetPackage="com.linkFlow.user.model" targetProject="linkflow-user/src/main/java"/>
        <sqlMapGenerator targetPackage="mapper" targetProject="linkflow-user/src/main/resources"/>
        <javaClientGenerator type="XMLMAPPER" targetPackage="com.linkFlow.user.mapper" targetProject="linkflow-user/src/main/java"/>

        <table tableName="approver_config" domainObjectName="ApproverConfig" catalog="short_link_db"/>
    </context>
</generatorConfiguration>
